# =============================================================================
# urban-auto-vox-rs configuration template.
#
# Copy to `.env` and edit; docker-compose reads it automatically and the
# Urban-Auto-Vox GUI (`gui-modern.sh`) writes the same keys.
# Every value is optional — defaults below match docker-compose.yml.
# =============================================================================

# ---- CityGML input version (the GUI writes this; start.sh reads it).
# 2.0  → run citygml-tools first (CityGML 2.0 → 3.0 upgrade)
# 3.0  → skip citygml-tools, feed data/citygml3/*.gml directly
CITYGML_INPUT_VERSION=2.0

# ---- PostGIS (compose.yml + Rust binary both consume these).
POSTGRES_DB=voxel_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5434

# ---- Pipeline tuning.
# Target voxel edge length, metres. The Rust pipeline picks a per-file
# adaptive grid size: clamp(ceil(max_dim / PIPELINE_VOXEL_SIZE), 8, 2048).
PIPELINE_VOXEL_SIZE=0.5

# EPSG code stamped onto every Point Z in the `voxel.vox_geom` column.
PIPELINE_DB_SRID=25832

# Concurrent cuda_voxelizer invocations. Tune to GPU memory headroom.
PIPELINE_NUM_WORKERS=8

# csv | postgis | both
PIPELINE_OUTPUT_FORMAT=csv

# COPY BINARY flush threshold in bytes. Larger → fewer round-trips,
# more memory. 8 MiB is a safe sweet spot.
PIPELINE_DB_BATCH_BYTES=8388608

# ---- Diagnostics.
# Rust log level: error | warn | info | debug | trace, optionally
# scoped, e.g. `voxel_pipeline=debug,info`.
RUST_LOG=info
RUST_BACKTRACE=1
